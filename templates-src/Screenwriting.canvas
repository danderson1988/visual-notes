            { "label": "II", "color": "#F59E0B" },
            { "label": "III", "color": "#DC2626" }
          ] },
          { "id": "bt-page", "label": "Page", "type": "number", "align": "right" },
          { "id": "bt-status", "label": "Status", "type": "select", "options": [
            { "label": "To write", "color": "#6B7280" },
            { "label": "Draft", "color": "#F59E0B" },
            { "label": "Locked", "color": "#10B981" }
          ] }
        ],
        "rows": [
          { "id": "btr-1", "cells": { "bt-beat": "Opening image", "bt-act": "I", "bt-page": "1", "bt-status": "To write" } },
          { "id": "btr-2", "cells": { "bt-beat": "Catalyst", "bt-act": "I", "bt-page": "12", "bt-status": "To write" } },
          { "id": "btr-3", "cells": { "bt-beat": "Break into two", "bt-act": "I", "bt-page": "25", "bt-status": "To write" } },
          { "id": "btr-4", "cells": { "bt-beat": "Midpoint", "bt-act": "II", "bt-page": "55", "bt-status": "To write" } },
          { "id": "btr-5", "cells": { "bt-beat": "All is lost", "bt-act": "II", "bt-page": "75", "bt-status": "To write" } },
          { "id": "btr-6", "cells": { "bt-beat": "Break into three", "bt-act": "III", "bt-page": "85", "bt-status": "To write" } },
          { "id": "btr-7", "cells": { "bt-beat": "Finale", "bt-act": "III", "bt-page": "110", "bt-status": "To write" } }
