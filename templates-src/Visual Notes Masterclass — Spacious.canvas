{
  "nodes": [
    { "id": "sp-title", "x": -1900, "y": -1050, "width": 3800, "height": 92, "type": "text", "text": "> [!note] 🌌 Visual Notes Masterclass — Spacious\n> The same visual toolkit, intentionally spread across an open canvas. Follow the connections, then make the space your own.", "color": "#7C3AED", "ib": { "kind": "callout", "id": "sp-title", "text": "The same visual toolkit, intentionally spread across an open canvas. Follow the connections, then make the space your own.", "icon": "🌌", "color": "#7C3AED" } },
    { "id": "sp-capture-group", "x": -1820, "y": -860, "width": 720, "height": 870, "type": "group", "label": "01 — Capture & discuss", "color": "#8B5CF6", "ib": { "kind": "group", "id": "sp-capture-group", "label": "01 — Capture & discuss", "color": "#8B5CF6" } },
    { "id": "sp-sticky", "x": -1760, "y": -780, "width": 290, "height": 210, "type": "text", "text": "💡 Sticky note\n\nA roomy place for a thought. Double-click to edit, select text to format it, or change the card shape and colour.", "color": "#FEF3C7", "ib": { "kind": "sticky", "id": "sp-sticky", "text": "💡 Sticky note\n\nA roomy place for a thought. Double-click to edit, select text to format it, or change the card shape and colour.", "color": "#FEF3C7", "topColor": "#F59E0B", "labels": [ { "id": "sp-l-idea", "text": "IDEA", "color": "#F59E0B" } ] } },
    { "id": "sp-card", "x": -1390, "y": -780, "width": 230, "height": 210, "type": "text", "text": "Blank Card\n\nUse a plain card as a visual label, an anchor, or a shape in a diagram.", "color": "#E0F2FE", "ib": { "kind": "sticky", "id": "sp-card", "text": "Blank Card\n\nUse a plain card as a visual label, an anchor, or a shape in a diagram.", "color": "#E0F2FE", "blank": true, "shape": "rect", "textAlign": "center" } },
    { "id": "sp-checklist", "x": -1760, "y": -490, "width": 290, "height": 270, "type": "text", "text": "### To-do checklist\n\n- [ ] **Explore**\n  - [ ] Write a note\n  - [ ] Style text\n- [ ] **Connect**\n  - [ ] Make a line\n  - [ ] Add a label", "color": "#FFFFFF", "ib": { "kind": "checklist", "id": "sp-checklist", "title": "To-do checklist", "color": "#FFFFFF", "accentColor": "#8B5CF6", "items": [ { "id": "spc-h1", "text": "Explore", "done": false, "isHeader": true }, { "id": "spc-1", "text": "Write a note", "done": false, "parentId": "spc-h1" }, { "id": "spc-2", "text": "Style text", "done": false, "parentId": "spc-h1" }, { "id": "spc-h2", "text": "Connect", "done": false, "isHeader": true }, { "id": "spc-3", "text": "Make a line", "done": false, "parentId": "spc-h2" }, { "id": "spc-4", "text": "Add a label", "done": false, "parentId": "spc-h2" } ] } },
    { "id": "sp-comment", "x": -1390, "y": -490, "width": 230, "height": 270, "type": "text", "text": "**Alex** _(today)_\nWhat makes this idea useful?\n\n---\n**You** _(today)_\nReply here, then resolve the thread when the decision is clear.", "color": "#FCE7F3", "ib": { "kind": "comment", "id": "sp-comment", "text": "What makes this idea useful?", "author": "Alex", "createdAt": 1783987200000, "color": "#FCE7F3", "replies": [ { "id": "spcr-1", "text": "Reply here, then resolve the thread when the decision is clear.", "author": "You", "createdAt": 1783990800000 } ] } },
    { "id": "sp-table", "x": -1760, "y": -130, "width": 600, "height": 115, "type": "text", "text": "### Typed table\n\n| Work item | Status | Due | Done |\n| --- | --- | --- | --- |\n| Explore canvas | In progress | 2026-07-15 |  |\n| Link ideas | Planned | 2026-07-18 |  |", "color": "#FFFFFF", "ib": { "kind": "table", "id": "sp-table", "title": "Typed table", "color": "#FFFFFF", "columns": [ { "id": "spt-work", "label": "Work item", "type": "text" }, { "id": "spt-status", "label": "Status", "type": "select", "options": [ { "label": "Planned", "color": "#DBEAFE" }, { "label": "In progress", "color": "#FEF3C7" }, { "label": "Done", "color": "#DCFCE7" } ] }, { "id": "spt-due", "label": "Due", "type": "date" }, { "id": "spt-done", "label": "Done", "type": "checkbox", "align": "center" } ], "rows": [ { "id": "sptr-1", "cells": { "spt-work": "Explore canvas", "spt-status": "In progress", "spt-due": "2026-07-15", "spt-done": "" } }, { "id": "sptr-2", "cells": { "spt-work": "Link ideas", "spt-status": "Planned", "spt-due": "2026-07-18", "spt-done": "" } } ] } },
    { "id": "sp-focus", "x": -410, "y": -850, "width": 390, "height": 210, "type": "file", "file": "_Templates/Visual Notes Masterclass — Deep Dive.canvas", "color": "#7C3AED", "ib": { "kind": "tile", "id": "sp-focus", "label": "Focus: Deep-dive workspace", "subtitle": "Open a linked canvas to work without distractions", "icon": "sparkles", "color": "#7C3AED", "target": { "kind": "board", "path": "_Templates/Visual Notes Masterclass — Deep Dive.canvas" }, "labels": [ { "id": "spf-label", "text": "START HERE", "color": "#7C3AED" } ], "reactions": [ "⭐" ] } },
